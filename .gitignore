# Build output
/build/

# Generated simulation output logs (see examples/*.json's log_path)
/output/*
!/output/.gitkeep

# Editor / local tooling
.vscode/
# Local Claude Code permission grants (machine-specific), but NOT
# .claude/skills/ - those are project-scoped and meant to be committed.
.claude/settings.local.json

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# debug information files
*.dwo

# Python
__pycache__/
*.pyc
